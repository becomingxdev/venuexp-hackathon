rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Crowd states are public for reading, but restricted for writing
    match /crowd_states/{zoneId} {
      allow read: if true;
      allow write: if false; // Only updated via IoT Aggregator (Service Account)
    }

    // Gates and Concessions: Public read, no public write
    match /gates/{gateId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /concessions/{concessionId} {
      allow read: if true;
      allow write: if false;
    }

    // User-specific data: Private to that user
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Orders: Private to the authenticated user who placed them
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.token.role == 'ops-staff');
      allow update: if request.auth != null && request.auth.token.role == 'ops-staff';
    }

    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
