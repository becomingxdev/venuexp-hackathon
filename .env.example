# ==============================================================================
# VenueXP Environment Variables
# ==============================================================================

# ------------------------------------------------------------------------------
# API (apps/api)
# ------------------------------------------------------------------------------
# Port for the Express API server
PORT=3000

# Required locally so firebase-admin can verify tokens and reach Firestore.
# In production on Google Cloud Run, Workload Identity is used instead.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/firebase-service-account-key.json

# ------------------------------------------------------------------------------
# Mobile (apps/mobile)
# ------------------------------------------------------------------------------
# Firebase JS SDK Configuration (from Firebase Console -> Project Settings -> General -> Web App)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=venuexp-yourproject.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=venuexp-yourproject
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=venuexp-yourproject.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
